root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{sh,bash,bats}]
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4

[{go.mod,go.sum}]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab
