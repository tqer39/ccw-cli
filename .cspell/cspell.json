{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./project-words.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["project-words"],
  "ignorePaths": [
    ".git/**",
    "node_modules/**",
    "dist/**",
    "vendor/**",
    "coverage.*",
    "*.prof",
    "go.sum",
    "go.mod",
    ".cspell/**",
    ".claude/**",
    "docs/superpowers/**",
    "internal/superpowers/preamble_*.txt",
    "tests/fixtures/**",
    ".goreleaser.yaml",
    "Formula/**",
    "*.png",
    "*.jpg",
    "*.jpeg",
    "*.gif",
    "*.ico",
    "*.tape",
    "*.gz",
    "*.zip",
    "*.exe",
    "*.dll",
    "*.so",
    "*.dylib"
  ]
}
