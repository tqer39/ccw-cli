#!/usr/bin/env bash
# ccw - Claude Code worktree launcher
# https://github.com/tqer39/ccw-cli
#
# shellcheck disable=SC2034  # color vars wired for future use
# shellcheck disable=SC2329  # helper fns referenced after later tasks wire them up

set -euo pipefail

if [[ -n "${CCW_DEBUG:-}" ]]; then
  set -x
  export PS4='+ ${BASH_SOURCE##*/}:${LINENO}: '
fi

# ----------------------------------------------------------------------------
# color helpers
# ----------------------------------------------------------------------------
init_color() {
  if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    C_RESET=$'\033[0m'
    C_BOLD=$'\033[1m'
    C_DIM=$'\033[2m'
    C_INV=$'\033[7m'
    C_YELLOW=$'\033[1;33m'
    C_RED=$'\033[1;31m'
    C_GREEN=$'\033[1;32m'
    C_CYAN=$'\033[1;36m'
  else
    C_RESET="" C_BOLD="" C_DIM="" C_INV=""
    C_YELLOW="" C_RED="" C_GREEN="" C_CYAN=""
  fi
}

warn()    { printf '%s⚠️  warning:%s %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
error()   { printf '%s✖ error:%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; }
info()    { printf '%s\n' "$*"; }
success() { printf '%s✓%s %s\n' "$C_GREEN" "$C_RESET" "$*"; }

# ----------------------------------------------------------------------------
# help / version
# ----------------------------------------------------------------------------
print_help() {
  cat <<'EOF'
Usage: ccw [options] [-- <claude-args>...]

Claude Code worktree launcher.

Options:
  -n, --new            常に新規 worktree で起動（既存 worktree の選択をスキップ）
  -s, --superpowers    superpowers プリアンブルを注入して起動
      --update         ccw を最新版に更新
      --uninstall      ccw 自身をアンインストール
  -v, --version        バージョン情報を表示
  -h, --help           このヘルプを表示

Arguments after `--` are forwarded to `claude` verbatim.

Examples:
  ccw                            既存 worktree があれば選択、なければ新規起動
  ccw -n                         既存を無視して新規 worktree で起動
  ccw -s                         新規 worktree + superpowers
  ccw -- --model claude-opus-4-7 claude へ引数をパススルー
  ccw --update                   リモートから pull
  ccw --uninstall                ccw を削除

Environment:
  NO_COLOR=1       カラー出力を無効化
  CCW_DEBUG=1      詳細ログ出力 (set -x)

Exit codes:
  0  success
  1  user error / cancellation
  *  passthrough from `claude`
EOF
}

resolve_ccw_repo() {
  local self real
  self="$(command -v ccw 2>/dev/null || printf '%s' "$0")"
  real="$(readlink -f "$self" 2>/dev/null || readlink "$self" 2>/dev/null || printf '%s' "$self")"
  (cd "$(dirname "$real")/.." && pwd)
}

print_version() {
  local repo version date
  repo="$(resolve_ccw_repo)"
  if [[ -d "$repo/.git" ]]; then
    version="$(git -C "$repo" describe --always --tags --dirty 2>/dev/null || printf 'unknown')"
    date="$(git -C "$repo" log -1 --format=%cs 2>/dev/null || printf 'unknown')"
  else
    version="unknown"
    date="unknown"
  fi
  printf 'ccw %s (%s)\n' "$version" "$date"
}

# ----------------------------------------------------------------------------
# update
# ----------------------------------------------------------------------------
run_update() {
  local repo
  repo="$(resolve_ccw_repo)"

  if [[ ! -d "$repo/.git" ]]; then
    error "ccw repository not found or not a git repo: $repo"
    exit 1
  fi

  info "ccw updater"
  info ""
  info "Repository: $repo"

  local branch current_sha current_msg
  branch="$(git -C "$repo" rev-parse --abbrev-ref HEAD)"
  current_sha="$(git -C "$repo" rev-parse --short HEAD)"
  current_msg="$(git -C "$repo" log -1 --format='%s (%cs)' HEAD)"
  info "Current:    $branch @ $current_sha  \"$current_msg\""

  if [[ "$branch" != "main" ]]; then
    warn "current branch is '$branch', not 'main'."
    if [[ ! -t 0 ]]; then exit 1; fi
    local ans
    read -rp "Continue anyway? [y/N]: " ans
    case "$ans" in
      y|Y|yes|YES) ;;
      *) info "Cancelled."; exit 0 ;;
    esac
  fi

  local dirty
  dirty="$(git -C "$repo" status --porcelain)"
  if [[ -n "$dirty" ]]; then
    error "local modifications detected. Commit or stash them before updating:"
    printf '%s\n' "$dirty" | sed 's/^/  /' >&2
    exit 1
  fi

  info "Fetching origin..."
  if ! git -C "$repo" fetch origin --quiet; then
    error "git fetch failed."
    exit 1
  fi

  local remote_sha remote_msg
  remote_sha="$(git -C "$repo" rev-parse --short "origin/${branch}" 2>/dev/null)" || {
    error "no remote tracking for origin/${branch}"
    exit 1
  }
  remote_msg="$(git -C "$repo" log -1 --format='%s (%cs)' "origin/${branch}")"
  info "Remote:     origin/${branch} @ $remote_sha  \"$remote_msg\""

  if [[ "$current_sha" == "$remote_sha" ]]; then
    success "Already up to date."
    exit 0
  fi

  info ""
  info "New commits:"
  git -C "$repo" log --oneline --no-decorate "HEAD..origin/${branch}" | head -10 | sed 's/^/  /'
  local total
  total="$(git -C "$repo" rev-list --count "HEAD..origin/${branch}")"
  if [[ "$total" -gt 10 ]]; then
    info "  ... and $((total - 10)) more"
  fi
  info ""

  if [[ ! -t 0 ]]; then
    info "(non-interactive: cancelled)"
    exit 1
  fi

  local ans2
  read -rp "Update now? [y/N]: " ans2
  case "$ans2" in
    y|Y|yes|YES) ;;
    *) info "Cancelled."; exit 0 ;;
  esac

  if git -C "$repo" pull --ff-only --quiet origin "$branch"; then
    success "Updated to: $(git -C "$repo" rev-parse --short HEAD)  \"$(git -C "$repo" log -1 --format='%s (%cs)')\""
  else
    error "git pull --ff-only failed. You may need to reset/rebase manually."
    exit 1
  fi
}

# ----------------------------------------------------------------------------
# uninstall
# ----------------------------------------------------------------------------
run_uninstall() {
  local self real repo
  self="$(command -v ccw 2>/dev/null || printf '%s' "$0")"
  real="$(readlink -f "$self" 2>/dev/null || readlink "$self" 2>/dev/null || printf '%s' "$self")"
  repo="$(cd "$(dirname "$real")/.." && pwd)"

  info "ccw uninstaller"
  info ""
  info "This removes the symlink only:"
  info "  symlink: $self"
  if [[ "$self" != "$real" ]]; then
    info "         → $real"
  fi
  info ""
  info "The cloned repo is kept as-is:"
  info "  repo:    $repo"
  info ""
  info "If you also want to delete the repo, remove it manually afterwards:"
  info "  rm -rf $repo"
  info ""

  if [[ ! -t 0 ]]; then
    info "(non-interactive: cancelled)"
    exit 1
  fi

  local ans
  read -rp "Remove symlink? [y/N]: " ans
  case "$ans" in
    y|Y|yes|YES) ;;
    *) info "Cancelled."; exit 0 ;;
  esac

  if [[ -L "$self" ]]; then
    rm -v "$self"
    success "Removed symlink."
  else
    warn "no symlink found at $self (nothing to remove)"
  fi

  info ""
  info "You may also remove PATH entry for \$HOME/.local/bin if no longer needed."
}

# ----------------------------------------------------------------------------
# git helpers
# ----------------------------------------------------------------------------
# worktree 内から呼ばれても main repo のトップレベルを返す
resolve_main_repo() {
  local common_dir
  common_dir="$(git rev-parse --git-common-dir 2>/dev/null)" || return 1
  common_dir="$(cd "$common_dir" && pwd -P)"
  dirname "$common_dir"
}

require_git_repo() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    warn "ccw must be run inside a git repository."
    info "  current directory: ${PWD}"
    info "  hint: cd into an existing repo, or run \`git init\` to create one."
    exit 1
  fi
}

# ----------------------------------------------------------------------------
# dependency checks
# ----------------------------------------------------------------------------
# 基盤ツール (git/brew/npm): 欠落時に URL 案内して exit 1
check_base_tool_or_exit() {
  local tool="$1" url="$2"
  if command -v "$tool" >/dev/null 2>&1; then
    return 0
  fi
  warn "missing dependency: $tool"
  info ""
  info "Install it from the official page, then rerun ccw:"
  info "  $url"
  exit 1
}

# ----------------------------------------------------------------------------
# claude launch
# ----------------------------------------------------------------------------
# 新規 worktree で claude を起動する
# $1: superpowers preamble (空文字なら preamble なし)
# その後の引数: claude への pass-through 引数
launch_claude_new() {
  local preamble="$1"
  shift
  local -a extra
  if [[ $# -gt 0 ]]; then
    extra=("$@")
  else
    extra=()
  fi

  local -a cmd=(claude --permission-mode auto --worktree)
  if [[ ${#extra[@]} -gt 0 ]]; then
    cmd+=("${extra[@]}")
  fi
  if [[ -n "$preamble" ]]; then
    cmd+=(-- "$preamble")
  fi

  "${cmd[@]}"
}

check_superpowers() {
  # ~/.claude/plugins/cache/*/superpowers/ を glob で検出
  local glob_pat="$HOME/.claude/plugins/cache/*/superpowers"
  if compgen -G "$glob_pat" >/dev/null 2>&1; then
    return 0
  fi

  warn "missing dependency: superpowers plugin (required for -s)"
  info ""
  info "The following command will install it:"
  info "  claude plugin install claude-plugins-official/superpowers"
  info ""
  info "(※ 正式コマンドは未確定。失敗する場合は手動でプラグインを追加してください。"
  info "    reference: https://docs.claude.com/en/docs/claude-code/plugins )"
  info ""

  if [[ ! -t 0 ]]; then
    info "(non-interactive: cancelled)"
    exit 1
  fi

  local ans
  read -rp "Run now? [y/N]: " ans
  case "$ans" in
    y|Y|yes|YES) ;;
    *) info "Cancelled."; exit 1 ;;
  esac

  if ! claude plugin install claude-plugins-official/superpowers; then
    error "plugin install failed. Install manually and rerun."
    exit 1
  fi
}

# ----------------------------------------------------------------------------
# gitignore check (for -s)
# ----------------------------------------------------------------------------
ensure_gitignore() {
  local main_repo="$1"
  # 既に ignore 対象なら何もしない
  if (cd "$main_repo" && git check-ignore -q docs/superpowers/) 2>/dev/null; then
    return 0
  fi

  local gitignore="$main_repo/.gitignore"
  warn "docs/superpowers/ is not ignored by git."
  info ""
  info "superpowers skill は以下のファイルを生成します:"
  info "  - docs/superpowers/specs/"
  info "  - docs/superpowers/plans/"
  info ""
  info "The following block will be appended to $gitignore:"
  info ""
  info "  # superpowers workflow artifacts"
  info "  docs/superpowers/"
  info ""

  if [[ ! -t 0 ]]; then
    info "(non-interactive: skip without modifying)"
    return 0
  fi

  local ans
  read -rp "Add to .gitignore? [y/N]: " ans
  case "$ans" in
    y|Y|yes|YES) ;;
    *) return 0 ;;
  esac

  if [[ -f "$gitignore" && -s "$gitignore" ]]; then
    local last
    last="$(tail -c 1 "$gitignore" 2>/dev/null || printf '')"
    if [[ "$last" != $'\n' ]]; then
      printf '\n' >> "$gitignore"
    fi
  fi
  printf '\n# superpowers workflow artifacts\ndocs/superpowers/\n' >> "$gitignore"
  success "Added to $gitignore"
}

# ----------------------------------------------------------------------------
# worktree picker
# ----------------------------------------------------------------------------
# .claude/worktrees/* 配下の worktree を列挙する。
# 各行: <path>\t<branch>
list_ccw_worktrees() {
  local main_repo="$1"
  git -C "$main_repo" worktree list --porcelain 2>/dev/null | awk '
    /^worktree / { path=$2; branch=""; next }
    /^branch / { branch=$2; next }
    /^$/ {
      if (path != "" && path ~ /\/\.claude\/worktrees\//) {
        sub("refs/heads/", "", branch)
        printf "%s\t%s\n", path, branch
      }
      path=""; branch=""
    }
    END {
      if (path != "" && path ~ /\/\.claude\/worktrees\//) {
        sub("refs/heads/", "", branch)
        printf "%s\t%s\n", path, branch
      }
    }
  '
}

# worktree のステータスを 1 行で返す (dirty | local-only | pushed)
worktree_flags() {
  local wt="$1"
  if [[ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ]]; then
    printf 'dirty'
    return
  fi
  local upstream
  upstream="$(git -C "$wt" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
  if [[ -z "$upstream" ]]; then
    printf 'local-only'
    return
  fi
  local ahead
  ahead="$(git -C "$wt" rev-list --count '@{u}..HEAD' 2>/dev/null || printf '0')"
  if [[ "$ahead" == "0" ]]; then
    printf 'pushed'
  else
    printf 'local-only'
  fi
}

worktree_icon() {
  case "$1" in
    pushed)     printf '🟢' ;;
    local-only) printf '🟡' ;;
    dirty)      printf '🔴' ;;
    *)          printf '❔' ;;
  esac
}

# bash + tput で ↑↓ 選択 UI を提供する。
# 引数: 表示文字列の配列
# 結果: 選択したインデックス (0-based) を stdout に出力。キャンセルで 1 を返す。
tui_select() {
  local -a items=("$@")
  local n=${#items[@]}
  if [[ $n -eq 0 ]]; then
    return 1
  fi

  if [[ ! -t 0 || ! -t 1 ]]; then
    tui_select_fallback "${items[@]}"
    return $?
  fi

  local sel=0
  local drawn=0
  tput civis 2>/dev/null || true
  local orig_trap
  orig_trap="$(trap -p INT)"
  trap 'tput cnorm 2>/dev/null || true; exit 130' INT

  while true; do
    if [[ $drawn -eq 1 ]]; then
      tput cuu "$n" 2>/dev/null || true
    fi
    local i
    for i in "${!items[@]}"; do
      tput el 2>/dev/null || true
      if [[ $i -eq $sel ]]; then
        printf '%s> %s%s\n' "$C_INV" "${items[$i]}" "$C_RESET" >&2
      else
        printf '  %s\n' "${items[$i]}" >&2
      fi
    done
    drawn=1

    local key rest
    IFS= read -rsn1 key
    if [[ "$key" == $'\e' ]]; then
      IFS= read -rsn2 -t 0.01 rest || rest=""
      case "$rest" in
        '[A') sel=$(( (sel - 1 + n) % n )) ;;
        '[B') sel=$(( (sel + 1) % n )) ;;
      esac
    elif [[ -z "$key" ]]; then
      tput cnorm 2>/dev/null || true
      eval "$orig_trap" 2>/dev/null || trap - INT
      printf '%d\n' "$sel"
      return 0
    elif [[ "$key" == "q" || "$key" == "Q" ]]; then
      tput cnorm 2>/dev/null || true
      eval "$orig_trap" 2>/dev/null || trap - INT
      return 1
    fi
  done
}

# tty がない場合の番号選択 fallback
tui_select_fallback() {
  local -a items=("$@")
  info "Select an item:" >&2
  local i
  for i in "${!items[@]}"; do
    printf '  %d) %s\n' "$((i + 1))" "${items[$i]}" >&2
  done
  local choice
  read -rp "#? " choice
  if [[ ! "$choice" =~ ^[0-9]+$ ]]; then
    return 1
  fi
  local idx=$((choice - 1))
  if (( idx < 0 || idx >= ${#items[@]} )); then
    return 1
  fi
  printf '%d\n' "$idx"
  return 0
}

superpowers_preamble() {
  cat <<'EOF'
このセッションは Claude Code の --worktree sandbox 内です。
superpowers:brainstorming → superpowers:writing-plans → superpowers:executing-plans
の順で進めてください。トピックはこれから相談します。
EOF
}

check_claude() {
  if command -v claude >/dev/null 2>&1; then
    return 0
  fi
  warn "missing dependency: claude (Claude Code CLI)"
  info ""
  info "Choose installer:"
  info "  [1] npm  (npm install -g @anthropic-ai/claude-code)"
  info "  [2] brew (brew install claude-code)"
  info "  [q] quit (install manually and rerun)"
  info ""

  if [[ ! -t 0 ]]; then
    info "(non-interactive: cancelled)"
    exit 1
  fi

  local choice
  read -rp "Select [1/2/q]: " choice
  case "$choice" in
    1)
      check_base_tool_or_exit "npm" "https://nodejs.org/"
      info ""
      info "Running: npm install -g @anthropic-ai/claude-code"
      npm install -g @anthropic-ai/claude-code
      ;;
    2)
      check_base_tool_or_exit "brew" "https://brew.sh"
      info ""
      info "Running: brew install claude-code"
      brew install claude-code
      ;;
    *)
      info "Cancelled."
      exit 1
      ;;
  esac
}

# ----------------------------------------------------------------------------
# argument parsing
# ----------------------------------------------------------------------------
# パース結果を以下のグローバル変数に設定する
#   FLAG_NEW / FLAG_SUPER / FLAG_UPDATE / FLAG_UNINSTALL / FLAG_VERSION / FLAG_HELP
#   CLAUDE_ARGS (配列)
parse_args() {
  FLAG_NEW=0
  FLAG_SUPER=0
  FLAG_UPDATE=0
  FLAG_UNINSTALL=0
  FLAG_VERSION=0
  FLAG_HELP=0
  CLAUDE_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)        FLAG_HELP=1; shift ;;
      -v|--version)     FLAG_VERSION=1; shift ;;
      -n|--new)         FLAG_NEW=1; shift ;;
      -s|--superpowers) FLAG_SUPER=1; shift ;;
      --update)         FLAG_UPDATE=1; shift ;;
      --uninstall)      FLAG_UNINSTALL=1; shift ;;
      --)
        shift
        CLAUDE_ARGS=("$@")
        break
        ;;
      -*)
        error "unknown option: $1"
        info "Run \`ccw -h\` for usage."
        exit 1
        ;;
      *)
        error "unknown argument: $1"
        info "Run \`ccw -h\` for usage."
        exit 1
        ;;
    esac
  done
}

# ----------------------------------------------------------------------------
# main
# ----------------------------------------------------------------------------
main() {
  init_color
  parse_args "$@"

  if [[ $FLAG_HELP -eq 1 ]]; then
    print_help
    exit 0
  fi
  if [[ $FLAG_VERSION -eq 1 ]]; then
    print_version
    exit 0
  fi
  if [[ $FLAG_UNINSTALL -eq 1 ]]; then
    run_uninstall
    exit 0
  fi
  if [[ $FLAG_UPDATE -eq 1 ]]; then
    run_update
    exit 0
  fi

  require_git_repo
  local main_repo
  main_repo="$(resolve_main_repo)" || {
    error "failed to resolve main repository root"
    exit 1
  }

  check_base_tool_or_exit "git" "https://git-scm.com/downloads"
  check_claude

  # main repo へ移動 (origin/HEAD 同期と claude 起動位置のため)
  cd "$main_repo"

  # origin/HEAD 同期 (失敗は無視)
  git remote set-head origin -a >/dev/null 2>&1 || true

  local preamble=""
  if [[ $FLAG_SUPER -eq 1 ]]; then
    check_superpowers
    ensure_gitignore "$main_repo"
    preamble="$(superpowers_preamble)"
  fi

  # -n または -s → 新規 worktree
  # (デフォルト picker は Task 14 で実装、暫定は新規起動にフォールバック)
  if [[ ${#CLAUDE_ARGS[@]} -gt 0 ]]; then
    launch_claude_new "$preamble" "${CLAUDE_ARGS[@]}"
  else
    launch_claude_new "$preamble"
  fi
  exit $?
}

main "$@"
